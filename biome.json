{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!**/dist",
      "!vite.config.ts",
      "!jest.config.js",
      "!coverage",
      "!**/coverage",
      "!public/sw.js",
      "!src/theme/Footer"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSpacing": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noImplicitAnyLet": "off",
        "noConsole": "warn"
      },
      "a11y": {
        "useValidAutocomplete": "off"
      },
      "complexity": {
        "noUselessFragments": "off",
        "noImportantStyles": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noNestedTernary": "warn",
        "useNamingConvention": {
          "level": "off"
        }
      },
      "nursery": {
        "noExcessiveClassesPerFile": "error",
        "noJsxPropsBind": "off",
        "noMultiAssign": "error",
        "noMultiStr": "error",
        "noProto": "error",
        "noReturnAssign": "error",
        "noScriptUrl": "error",
        "noUnknownAttribute": "error",
        "noUselessReturn": "error",
        "useDestructuring": "error",
        "useSpread": "error",
        "noForIn": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
